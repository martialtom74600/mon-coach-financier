{
  "name": "mon-coach-financier",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:fresh": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && next dev -p 3000",
    "dev:single": "(npx --yes kill-port 3000 || echo) && next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "prisma generate",
    "icons": "node scripts/generate-pwa-icons.js",
    "env:pull": "npx vercel env pull .env.local --yes && node scripts/sync-env-from-vercel.js",
    "env:pull:production": "npx vercel env pull .env.local --environment=production --yes && node scripts/sync-env-from-vercel.js"
  },
  "dependencies": {
    "@clerk/localizations": "^2.4.5",
    "@clerk/nextjs": "^5.1.6",
    "@ducanh2912/next-pwa": "^10.2.9",
    "@nivo/core": "^0.99.0",
    "@nivo/sankey": "^0.99.0",
    "@prisma/client": "^5.16.1",
    "@sentry/nextjs": "^10.42.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.4",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "lucide-react": "^0.395.0",
    "next": "^14.2.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "svix": "^1.89.0",
    "tailwind-merge": "^2.3.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari major versions",
    "last 2 Edge versions"
  ],
  "overrides": {
    "@clerk/clerk-js": "5.15.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "^10.4.19",
    "eslint": "^8",
    "eslint-config-next": "14.2.15",
    "postcss": "^8",
    "prisma": "^5.16.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
